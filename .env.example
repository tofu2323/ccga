# Claude Code OAuth Token
# Get this by running: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub Settings
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Agent Configuration
AGENT_COUNT=16
AGENT_MODEL=claude-opus-4-20250514
PARALLEL_EXECUTION=true

# Tmux Settings
TMUX_SESSION_NAME=claude-agents
TMUX_LAYOUT=tiled

# Security
PRIVATE_REPO_ONLY=true
AUTO_APPROVE_PR=false

# Optional: Anthropic API Key (for direct API usage)
# ANTHROPIC_API_KEY=

# Optional: Cloud Provider Settings
# For AWS Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# For Google Vertex AI
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=

# Performance Settings
MAX_CONCURRENT_AGENTS=16
AGENT_TIMEOUT_SECONDS=300
CACHE_RESPONSES=true

# Logging
LOG_LEVEL=info
SAVE_TRANSCRIPTS=true
TRANSCRIPT_PATH=.claude/transcripts

# Communication Settings
DEFAULT_LANGUAGE=ja
DOCUMENTATION_LEVEL=detailed
COMMENT_CODE=true

# Development Settings
NODE_ENV=development
DEBUG=false

# CI/CD Settings
RUN_TESTS_BEFORE_PR=true
AUTO_FORMAT_CODE=true
LINT_ON_COMMIT=true